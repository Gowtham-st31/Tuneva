# Copy this file to `.env` and fill in real secrets locally.
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=your_sender_email@example.com
BREVO_SENDER_NAME=Tuneva Music

# MongoDB Atlas configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?appName=Tuneva
MONGODB_DB_NAME=yt_music
MONGODB_AUTH_SOURCE=admin

# Comma-separated admin emails
ADMIN_EMAILS=tuneva2026@gmail.com
